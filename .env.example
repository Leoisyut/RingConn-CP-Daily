# Feishu custom bot webhook, for example:
# https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_WEBHOOK_URL=

# Optional. Enable signature verification in the Feishu bot security settings,
# then paste the secret here.
FEISHU_WEBHOOK_SECRET=

# Optional overrides.
RINGWATCH_CONFIG=config/competitors.json
RINGWATCH_STATE=.ringwatch/state.json
